MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_gmail_app_password
MAIL_RECIPIENT=muhammadali.tahirzadeh@gmail.com

# Secret required to access admin-only API endpoints (reading/editing/deleting
# messages and creating/editing/deleting projects). Generate a strong random
# value, e.g. `python -c "import secrets; print(secrets.token_urlsafe(32))"`.
# Send it as an `X-Admin-Token` header (or `Authorization: Bearer <token>`).
ADMIN_TOKEN=

# Set to true only for local development. Never enable in production: it exposes
# the Werkzeug interactive debugger, which allows remote code execution.
FLASK_DEBUG=false
FLASK_HOST=127.0.0.1
FLASK_PORT=5000
